{
  "functions": {
    "api/parse-listing.js": {
      "maxDuration": 60
    },
    "api/market-intel.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
